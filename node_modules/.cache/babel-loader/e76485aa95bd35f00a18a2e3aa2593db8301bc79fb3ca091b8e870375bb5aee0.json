{"ast":null,"code":"import{createSlice}from\"@reduxjs/toolkit\";const STORAGE_KEY=\"badee_wishlist_ids\";function readStoredIds(){try{const raw=JSON.parse(localStorage.getItem(STORAGE_KEY)||\"[]\");return Array.isArray(raw)?raw.map(String):[];}catch{return[];}}function persist(ids){localStorage.setItem(STORAGE_KEY,JSON.stringify(ids));}const wishlistSlice=createSlice({name:\"wishlist\",initialState:{ids:readStoredIds()},reducers:{toggleWishlist(state,action){const id=String(action.payload);const idx=state.ids.indexOf(id);if(idx>=0)state.ids.splice(idx,1);else state.ids.push(id);persist(state.ids);},removeFromWishlist(state,action){const id=String(action.payload);state.ids=state.ids.filter(x=>x!==id);persist(state.ids);}}});export const{toggleWishlist,removeFromWishlist}=wishlistSlice.actions;export default wishlistSlice.reducer;","map":{"version":3,"names":["createSlice","STORAGE_KEY","readStoredIds","raw","JSON","parse","localStorage","getItem","Array","isArray","map","String","persist","ids","setItem","stringify","wishlistSlice","name","initialState","reducers","toggleWishlist","state","action","id","payload","idx","indexOf","splice","push","removeFromWishlist","filter","x","actions","reducer"],"sources":["C:/Users/VIP17JUIN24/Desktop/cursor badee/src/redux/wishlistSlice.js"],"sourcesContent":["import { createSlice } from \"@reduxjs/toolkit\";\r\n\r\nconst STORAGE_KEY = \"badee_wishlist_ids\";\r\n\r\nfunction readStoredIds() {\r\n  try {\r\n    const raw = JSON.parse(localStorage.getItem(STORAGE_KEY) || \"[]\");\r\n    return Array.isArray(raw) ? raw.map(String) : [];\r\n  } catch {\r\n    return [];\r\n  }\r\n}\r\n\r\nfunction persist(ids) {\r\n  localStorage.setItem(STORAGE_KEY, JSON.stringify(ids));\r\n}\r\n\r\nconst wishlistSlice = createSlice({\r\n  name: \"wishlist\",\r\n  initialState: { ids: readStoredIds() },\r\n  reducers: {\r\n    toggleWishlist(state, action) {\r\n      const id = String(action.payload);\r\n      const idx = state.ids.indexOf(id);\r\n      if (idx >= 0) state.ids.splice(idx, 1);\r\n      else state.ids.push(id);\r\n      persist(state.ids);\r\n    },\r\n    removeFromWishlist(state, action) {\r\n      const id = String(action.payload);\r\n      state.ids = state.ids.filter((x) => x !== id);\r\n      persist(state.ids);\r\n    },\r\n  },\r\n});\r\n\r\nexport const { toggleWishlist, removeFromWishlist } = wishlistSlice.actions;\r\nexport default wishlistSlice.reducer;\r\n"],"mappings":"AAAA,OAASA,WAAW,KAAQ,kBAAkB,CAE9C,KAAM,CAAAC,WAAW,CAAG,oBAAoB,CAExC,QAAS,CAAAC,aAAaA,CAAA,CAAG,CACvB,GAAI,CACF,KAAM,CAAAC,GAAG,CAAGC,IAAI,CAACC,KAAK,CAACC,YAAY,CAACC,OAAO,CAACN,WAAW,CAAC,EAAI,IAAI,CAAC,CACjE,MAAO,CAAAO,KAAK,CAACC,OAAO,CAACN,GAAG,CAAC,CAAGA,GAAG,CAACO,GAAG,CAACC,MAAM,CAAC,CAAG,EAAE,CAClD,CAAE,KAAM,CACN,MAAO,EAAE,CACX,CACF,CAEA,QAAS,CAAAC,OAAOA,CAACC,GAAG,CAAE,CACpBP,YAAY,CAACQ,OAAO,CAACb,WAAW,CAAEG,IAAI,CAACW,SAAS,CAACF,GAAG,CAAC,CAAC,CACxD,CAEA,KAAM,CAAAG,aAAa,CAAGhB,WAAW,CAAC,CAChCiB,IAAI,CAAE,UAAU,CAChBC,YAAY,CAAE,CAAEL,GAAG,CAAEX,aAAa,CAAC,CAAE,CAAC,CACtCiB,QAAQ,CAAE,CACRC,cAAcA,CAACC,KAAK,CAAEC,MAAM,CAAE,CAC5B,KAAM,CAAAC,EAAE,CAAGZ,MAAM,CAACW,MAAM,CAACE,OAAO,CAAC,CACjC,KAAM,CAAAC,GAAG,CAAGJ,KAAK,CAACR,GAAG,CAACa,OAAO,CAACH,EAAE,CAAC,CACjC,GAAIE,GAAG,EAAI,CAAC,CAAEJ,KAAK,CAACR,GAAG,CAACc,MAAM,CAACF,GAAG,CAAE,CAAC,CAAC,CAAC,IAClC,CAAAJ,KAAK,CAACR,GAAG,CAACe,IAAI,CAACL,EAAE,CAAC,CACvBX,OAAO,CAACS,KAAK,CAACR,GAAG,CAAC,CACpB,CAAC,CACDgB,kBAAkBA,CAACR,KAAK,CAAEC,MAAM,CAAE,CAChC,KAAM,CAAAC,EAAE,CAAGZ,MAAM,CAACW,MAAM,CAACE,OAAO,CAAC,CACjCH,KAAK,CAACR,GAAG,CAAGQ,KAAK,CAACR,GAAG,CAACiB,MAAM,CAAEC,CAAC,EAAKA,CAAC,GAAKR,EAAE,CAAC,CAC7CX,OAAO,CAACS,KAAK,CAACR,GAAG,CAAC,CACpB,CACF,CACF,CAAC,CAAC,CAEF,MAAO,MAAM,CAAEO,cAAc,CAAES,kBAAmB,CAAC,CAAGb,aAAa,CAACgB,OAAO,CAC3E,cAAe,CAAAhB,aAAa,CAACiB,OAAO","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}