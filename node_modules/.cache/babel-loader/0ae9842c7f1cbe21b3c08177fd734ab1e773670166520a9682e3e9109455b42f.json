n\nexport default function Sidebar({ searchParams, setSearchParams }) {\n  const [co, setCo] = useState(true);\n  const { t } = useLang();\n\n  const applyOption = (opt) => {\n    const p = opt.params || {};\n    if (!p.view && !p.category) {\n      setSearchParams({}, { replace: true });\n      return;\n    }\n    const next = {};\n    if (p.view) next.view = p.view;\n    if (p.category) next.category = p.category;\n    setSearchParams(next, { replace: true });\n  };\n\n  return (\n    <div style={{ minWidth: 210, maxWidth: 220 }} className=\"sb-col\">\n      <div className=\"sb-section\">\n        <div className=\"sb-title\" onClick={() => setCo(!co)}>\n          {t.cats}\n          <span>{co ? \"▾\" : \"▸\"}</span>\n        </div>\n        {co &&\n          SIDEBAR_FILTER_OPTIONS.map((opt) => {\n            const active = isSidebarOptionActive(opt, searchParams);\n            return (\n              <div\n                key={opt.label}\n                className=\"sb-item\"\n                onClick={() => applyOption(opt)}\n                style={{ color: active ? \"#D6247F\" : \"#666\", fontWeight: active ? 700 : 400 }}\n              >\n                <input type=\"checkbox\" checked={active} onChange={() => applyOption(opt)} readOnly />\n                {opt.label}\n              </div>\n            );\n          })}\n      </div>\n    </div>\n  );\n}\n"],"mappings":"AAAA,OAASA,QAAQ,KAAQ,OAAO,CAChC,OAASC,sBAAsB,CAAEC,qBAAqB,KAAQ,yBAAyB,CACvF,OAASC,OAAO,KAAQ,wBAAwB,CAAC,OAAAC,GAAA,IAAAC,IAAA,CAAAC,IAAA,IAAAC,KAAA,yBAEjD,cAAe,SAAS,CAAAC,OAAOA,CAAAC,IAAA,CAAoC,IAAnC,CAAEC,YAAY,CAAEC,eAAgB,CAAC,CAAAF,IAAA,CAC/D,KAAM,CAACG,EAAE,CAAEC,KAAK,CAAC,CAAGb,QAAQ,CAAC,IAAI,CAAC,CAClC,KAAM,CAAEc,CAAE,CAAC,CAAGX,OAAO,CAAC,CAAC,CAEvB,KAAM,CAAAY,WAAW,CAAIC,GAAG,EAAK,CAC3B,KAAM,CAAAC,CAAC,CAAGD,GAAG,CAACE,MAAM,EAAI,CAAC,CAAC,CAC1B,GAAI,CAACD,CAAC,CAACE,IAAI,EAAI,CAACF,CAAC,CAACG,QAAQ,CAAE,CAC1BT,eAAe,CAAC,CAAC,CAAC,CAAE,CAAEU,OAAO,CAAE,IAAK,CAAC,CAAC,CACtC,OACF,CACA,KAAM,CAAAC